{
  "expo": {
    "name": "FinTrack",
    "slug": "react-native-fintech-app",
    "version": "1.0.0",
    "description": "Track your crypto portfolio, trade coins, and set price alerts with real-time market data.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fintrack",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0052FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.norfrt6.fintrack",
      "config": {
        "usesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:fintrack.app",
        "applinks:www.fintrack.app"
      ],
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to securely access your portfolio",
        "NSCameraUsageDescription": "Scan QR codes for wallet addresses"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0052FF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.norfrt6.fintrack",
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "fintrack.app",
              "pathPrefix": "/coin"
            },
            {
              "scheme": "https",
              "host": "fintrack.app",
              "pathPrefix": "/trade"
            },
            {
              "scheme": "https",
              "host": "fintrack.app",
              "pathPrefix": "/markets"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow FinTrack to use Face ID for authentication"
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/fintrack-portfolio-app",
      "fallbackToCacheTimeout": 5000
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "fintrack-portfolio-app"
      }
    }
  }
}
